# Production environment template for InfixMart Next.js
# Copy to .env.local for local development or set these in your hosting provider.

NODE_ENV=production
PORT=3000

# App URLs
FRONTEND_URL=https://www.yourdomain.com
FRONTEND_URL_WWW=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_NAME=InfixMart Wholesale
ALLOWED_ORIGINS=https://www.yourdomain.com,https://yourdomain.com

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
# If your MySQL password is blank, keep the key and leave it empty:
# DB_PASSWORD=
DB_POOL_LIMIT=10

# JWT and session secrets
JWT_SECRET=replace_with_a_64_byte_hex_secret
JWT_SECRET_ACCESS_TOKEN=replace_with_a_different_64_byte_hex_secret
JWT_SECRET_REFRESH_TOKEN=replace_with_another_64_byte_hex_secret
PAYMENT_STATE_SECRET=replace_with_another_64_byte_hex_secret

# Cookie policy
COOKIE_DOMAIN=yourdomain.com
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true
CONTENT_SECURITY_POLICY=

# SMTP
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=support@yourdomain.com
SMTP_PASS=your_email_password
SMTP_FROM=support@yourdomain.com

# Admin bootstrap
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChooseAVeryStrongPasswordHere@2026
ADMIN_NAME=Admin

# Payments
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx

# OAuth
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_AUTH_WINDOW_MS=600000
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_ADMIN_WINDOW_MS=300000
RATE_LIMIT_ADMIN_MAX=120
RATE_LIMIT_PAYMENT_WINDOW_MS=300000
RATE_LIMIT_PAYMENT_MAX=20
RATE_LIMIT_UPLOAD_WINDOW_MS=300000
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_MUTATION_WINDOW_MS=60000
RATE_LIMIT_MUTATION_MAX=120
UPLOAD_MAX_FILE_SIZE_MB=8
UPLOAD_MAX_FILES=10
