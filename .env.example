# ══════════════════════════════════════════════════════════════════════════════
# InfixMart — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════════════
# 1. Copy this file to .env.local for local dev, or set these in Hostinger hPanel
#    → Website → Node.js → Environment Variables
# 2. NEVER commit .env.local or any file containing real secrets to git.
# 3. After changing secrets, restart your Node.js app in hPanel.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Database (MySQL) ──────────────────────────────────────────────────────────
# Get these from Hostinger hPanel → Databases → MySQL Databases
DB_HOST=localhost
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_database_username
DB_PASSWORD=your_strong_database_password

# In production, tables are never auto-altered. Leave this unset or false.
# DB_SYNC_ALTER=false

# ── JWT Secrets ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_STRING
JWT_SECRET_ACCESS_TOKEN=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_STRING
JWT_SECRET_REFRESH_TOKEN=REPLACE_WITH_ANOTHER_64_BYTE_HEX_STRING
PAYMENT_STATE_SECRET=REPLACE_WITH_ANOTHER_64_BYTE_HEX_STRING

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Hostinger business email SMTP settings:
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=support@yourdomain.com
SMTP_PASS=your_email_password

# ── URLs ─────────────────────────────────────────────────────────────────────
# Your actual domain (no trailing slash)
FRONTEND_URL=https://www.yourdomain.com
FRONTEND_URL_WWW=https://yourdomain.com

# ── Admin Credentials (used by create-admin script only) ─────────────────────
# Run: npm run create-admin  — after first deploy to create the admin user
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=ChooseAVeryStrongPasswordHere@2024
ADMIN_NAME=Admin

# ── Razorpay ──────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
# Enable auto-capture in the Razorpay dashboard before using live traffic.
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Public environment variables (exposed to browser) ────────────────────────
NEXT_PUBLIC_API_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_URL=https://www.yourdomain.com
NEXT_PUBLIC_SITE_NAME=InfixMart Wholesale

# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# This is the PUBLIC Razorpay key (safe to expose)
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
