# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/

# ── Next.js build output ──────────────────────────────────────────────────────
# .next/ is committed so Hostinger doesn't need to build on the server
.next/cache/
out/

# ── Environment variables (NEVER commit these) ────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# ── Uploaded user files (large binaries, not part of source code) ─────────────
# uploads/.gitkeep is committed so the empty folder is tracked.
# All actual uploaded files are excluded:
uploads/*
!uploads/.gitkeep

# ── Logs ──────────────────────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS / Editor ───────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
*.swp
*.swo

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tgz
*.tar.gz
